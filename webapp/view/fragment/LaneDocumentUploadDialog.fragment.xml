<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:unified="sap.ui.unified">
    <Dialog id="uploadDialog" title="Upload Document" contentWidth="500px" draggable="true">
        <content>
            <l:VerticalLayout width="100%">
                <l:content>
                    <VBox class="sapUiMediumMargin">
                        <Label text="Document Type" required="true" class="sapUiTinyMarginBottom" />
                        <Select id="docTypeSelect" width="100%" class="sapUiSmallMarginBottom">
                            <items>
                                <core:Item text="Bill of Lading" key="BOL" />
                                <core:Item text="Commercial Invoice" key="INVOICE" />
                                <core:Item text="Packing List" key="PACKING" />
                                <core:Item text="Certificate of Origin" key="COO" />
                                <core:Item text="Customs Declaration" key="CUSTOMS" />
                                <core:Item text="Insurance Certificate" key="INSURANCE" />
                                <core:Item text="Other" key="OTHER" />
                            </items>
                        </Select>
                        <Label text="Description" class="sapUiTinyMarginBottom" />
                        <TextArea id="docDescriptionInput" width="100%" rows="3" placeholder="Optional document description" class="sapUiSmallMarginBottom" />
                        <Label text="File" required="true" class="sapUiTinyMarginBottom" />
                        <unified:FileUploader id="fileUploader" width="100%" placeholder="Choose a file..." fileType="pdf,xlsx,xls,docx,png,jpg" maximumFileSize="10" fileSizeExceed=".onFileSizeExceed" typeMismatch=".onFileTypeMismatch" />
                        <MessageStrip
                            text="Accepted formats: PDF, Excel, Word, PNG, JPG (max 10 MB)"
                            type="Information"
                            showIcon="true"
                            showCloseButton="false"
                            class="sapUiTinyMarginBottom sapUiSmallMarginTop" />
                    </VBox>
                </l:content>
            </l:VerticalLayout>
        </content>
        <beginButton>
            <Button text="Upload" type="Emphasized" press=".onConfirmUpload" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCancelUpload" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
